generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Platform user. Linked to credentials as an earner (recipient).
model User {
  id          String             @id @default(cuid())
  email       String             @unique
  name        String?
  role        Role               @default(EARNER)
  /// OTP fields for email-based authentication
  otpCode     String?            @map("otp_code")
  otpExpiry   DateTime?          @map("otp_expiry")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  credentials IssuedCredential[]

  @@map("users")
}

/// Organization or individual that issues credentials.
/// Each issuer holds an Ed25519 key pair for cryptographic signing.
model IssuerProfile {
  id          String             @id @default(cuid())
  name        String
  logoUrl     String?            @map("logo_url")
  website     String?
  /// Ed25519 public key (base58-encoded). Shared publicly for verification.
  publicKey   String             @map("public_key")
  /// Ed25519 private key (base58-encoded).
  /// ⚠️  In production, encrypt at rest or use a KMS. For MVP, loaded from env.
  privateKey  String             @map("private_key")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  credentials IssuedCredential[]

  @@map("issuer_profiles")
}

/// A single issued credential conforming to Open Badges 3.0.
/// The full signed JSON-LD payload is stored in the `jsonLd` column.
model IssuedCredential {
  id          String        @id @default(cuid())
  /// Unique badge identifier used in claim URLs and JSON-LD `id` field.
  /// Format: UUID v4
  badgeId     String        @unique @map("badge_id")
  /// Credential metadata
  name        String
  description String
  criteriaUrl String?       @map("criteria_url")
  evidenceUrl String?       @map("evidence_url")
  /// Lifecycle
  issuedAt    DateTime      @default(now()) @map("issued_at")
  expiresAt   DateTime?     @map("expires_at")
  status      Status        @default(PENDING)
  /// Privacy: controls whether this credential is publicly visible
  isPublic    Boolean       @default(false) @map("is_public")
  /// Full Open Badges 3.0 JSON-LD payload (signed)
  jsonLd      Json          @map("json_ld")
  /// Relations
  recipientId String        @map("recipient_id")
  issuerId    String        @map("issuer_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  issuer      IssuerProfile @relation(fields: [issuerId], references: [id], onDelete: Cascade)
  recipient   User          @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([issuerId])
  @@index([status])
  @@map("issued_credentials")
}

enum Role {
  ADMIN
  ISSUER
  EARNER
  VERIFIER
}

enum Status {
  PENDING
  CLAIMED
  REVOKED
  EXPIRED
}
